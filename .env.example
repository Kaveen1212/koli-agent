# ── Core ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=postgresql://koli_user:koli_pass@localhost:5432/koli_art
SECRET_KEY=change_me

# ── Public URL (used to build image URLs) ─────────────────────────
PUBLIC_BASE_URL=http://localhost:8000

# ── CORS (comma-separated frontend origins) ──────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Limits & cost ─────────────────────────────────────────────────
MAX_GENERATIONS_PER_DAY=20
MAX_HISTORY_TURNS=20
COST_PER_GENERATION=0.039

# ── Models ────────────────────────────────────────────────────────
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=3072
IMAGE_MODEL=gemini-3.1-flash-image
VISION_MODEL=gemini-2.5-flash
AGENT_MODEL=gemini-2.5-flash

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=koli_redis_pass

# ── LangSmith tracing (optional) ──────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=koli-art-agent

# ── Storage: Cloudflare R2 or AWS S3 (leave empty for local disk) ──
STORAGE_BUCKET=koli-art-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_ENDPOINT_URL=
AWS_CLOUDFRONT_URL=
